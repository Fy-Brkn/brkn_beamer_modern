	\newlength{\mcmBlockTitleIndent}
	\setlength{\mcmBlockTitleIndent}{0.3em}
	
	\setbeamertemplate{block begin}{%
		\par\vskip0.6ex%
		\begin{tikzpicture}[every node/.style={}]
			\node[
			draw=none,
			rounded corners=5pt,
			fill=mcmBg,
			inner xsep=\mcmBlockPad,
			inner ysep=0.5ex,
			text width=\dimexpr\textwidth-2\mcmBlockPad-2pt\relax,
			anchor=north west
			] \bgroup
			{\hspace{\mcmBlockTitleIndent}%
				\llap{\tikz[baseline=0pt]{
						\fill[mcmPip, rounded corners=1pt]
						(0,0) rectangle (3pt,1.75ex);
					}\hspace{0.25em}}%
				\usebeamerfont{block title}\usebeamercolor[fg]{block title}%
				\insertblocktitle\par}%
			\vskip0.4ex
			\usebeamerfont{block body}\usebeamercolor[fg]{block body}%
		}
		\setbeamertemplate{block end}{%
			\egroup;
		\end{tikzpicture}%
		\vskip0.7ex%
	}
	
	
