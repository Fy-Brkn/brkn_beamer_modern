	\newcommand{\mcmFootlineContent}{%
		\begin{tikzpicture}[remember picture, overlay]
			\fill[mcmPrimaryMuted]
			([yshift=0.1cm]current page.south west)
			rectangle ([yshift=0.30cm]current page.south east);
				%Akzentliniedarüber
			\fill[mcmPrimary!55,rounded corners =1.5pt] ([yshift=0.30cm,xshift=0.05cm]current page.south west)
			rectangle ([yshift=0.42cm,xshift=-0.05cm]current page.south east);
			%Progrss balekn
			\pgfmathsetmacro{\mcmprog}{\insertframenumber / \inserttotalframenumber}%
			\fill[mcmPrimary,rounded corners=2.7pt]
			([yshift=0.1cm]current page.south west)
			rectangle ([xshift=\mcmprog\paperwidth, yshift=0.30cm]current page.south west);
			%Seitenanzeige
			\node[mcmPrimaryFg] at ([yshift=0.2cm,xshift = 0.5cm]current page.south west) {\insertframenumber};
			
		% Sektions-Ticks (dicker, volle Höhe)
		\foreach \sframe in \mcmSectionFrames {%
			\pgfmathsetmacro{\tickx}{\sframe / \inserttotalframenumber}%
			% Rand
			\fill[mcmBg, rounded corners=1.3pt]
			([xshift=\tickx\paperwidth - 0.8pt, yshift=0.11cm, yshift=-0.05cm,xshift=-0.01cm,yshift=-0.01]current page.south west)
			rectangle
			([xshift=\tickx\paperwidth + 1pt, yshift=0.35cm,xshift=0.01cm,yshift=0.01cm]current page.south west);
			% Tick
			\fill[mcmPip, rounded corners=1pt]
			([xshift=\tickx\paperwidth - 0.8pt, yshift=0.1cm, yshift=-0.05cm]current page.south west)
			rectangle
			([xshift=\tickx\paperwidth + 1pt, yshift=0.35cm]current page.south west);
		}
		
		% Subsektions-Ticks (schmaler, kürzer, tiefer)
		\foreach \sframe in \mcmSubSectionFrames {%
			\pgfmathsetmacro{\tickx}{\sframe / \inserttotalframenumber}%
			% Rand
			\fill[mcmBg, rounded corners=0.9pt]
			([xshift=\tickx\paperwidth - 0.8pt, yshift=0.1cm, yshift=-0.05cm,xshift=-0.01cm]current page.south west)
			rectangle
			([xshift=\tickx\paperwidth + 0.5pt, yshift=0.36cm,xshift=0.01cm]current page.south west);
			% Tick
			\fill[mcmPip!75, rounded corners=0.5pt]
			([xshift=\tickx\paperwidth - 0.8pt, yshift=0.1cm, yshift=-0.05cm]current page.south west)
			rectangle
			([xshift=\tickx\paperwidth + 0.5pt, yshift=0.35cm]current page.south west);
		}
			
			
		
			
%			\node[anchor=south west, inner sep=0pt]
%			at ([xshift=0.4cm, yshift=0.10cm]current page.south west)
%			{{\tiny\color{mcmBlack!45}\insertshortauthor}};
%			\node[anchor=south, inner sep=0pt]
%			at ([yshift=0.10cm]current page.south)
%			{{\tiny\color{mcmBlack!45}\insertshorttitle}};
%			\node[anchor=south east, inner sep=0pt]
%			at ([xshift=-0.4cm, yshift=0.10cm]current page.south east)
%			{{\tiny\color{mcmBlack!45}\textbf{\insertframenumber}\,/\,\inserttotalframenumber}};
		\end{tikzpicture}%
		\leavevmode\hbox to \paperwidth{\vbox to 0.45cm{}\hss}%
	}
	
