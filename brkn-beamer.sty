	% Nummern für sections
	\newcommand{\mcmSectionFrames}{}
	
	\newcommand{\mcmAddSection}[1]{%
		\ifx\mcmSectionFrames\empty
		\gdef\mcmSectionFrames{#1}%
		\else
		\expandafter\gdef\expandafter\mcmSectionFrames
		\expandafter{\mcmSectionFrames,#1}%
		\fi
	}
	
	\pretocmd{\beamer@section}{%
		\write\@auxout{%
			\string\mcmAddSection{\the\c@page}%
		}%
	}{}{\PackageWarning{mcm}{Patching beamer@section failed}}
	
	% Subsection-Liste
	\newcommand{\mcmSubSectionFrames}{}
	
	\newcommand{\mcmAddSubSection}[1]{%
		\ifx\mcmSubSectionFrames\empty
		\gdef\mcmSubSectionFrames{#1}%
		\else
		\edef\mcmtemp{\mcmSubSectionFrames}%
		\gdef\mcmSubSectionFrames{}%
		\xdef\mcmSubSectionFrames{\mcmtemp,#1}%
		\fi
	}
	
	\pretocmd{\beamer@subsection}{%
		\write\@auxout{%
			\string\mcmAddSubSection{\the\c@page}%
		}%
	}{}{\PackageWarning{mcm}{Patching beamer@subsection failed}}
	
